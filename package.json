{
  "name": "@umelainteligence.cz/plaud",
  "version": "0.1.7",
  "description": "Agent-first CLI + skill to export/download Plaud recordings (transcripts, summaries, audio). Fork of danielgwilson/plaud with EU region support.",
  "license": "MIT",
  "author": "Daniel G Wilson",
  "type": "module",
  "keywords": [
    "plaud",
    "cli",
    "export",
    "transcript",
    "audio",
    "agent",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Umelainteligence-cz/plaud.git"
  },
  "bugs": {
    "url": "https://github.com/Umelainteligence-cz/plaud/issues"
  },
  "homepage": "https://github.com/Umelainteligence-cz/plaud#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "plaud": "dist/cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json && node -e \"require('node:fs').chmodSync('dist/cli.js',0o755)\"",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "lint:public-surface": "node scripts/public-surface-check.mjs",
    "pretest": "npm run build",
    "test": "tsx --test",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run lint && npm run lint:public-surface && npm test",
    "prepare": "npm run build"
  },
  "files": [
    "dist/",
    "skills/",
    "docs/",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "playwright-core": "^1.51.1",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/yazl": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
